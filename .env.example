# Notion integration token (https://www.notion.so/my-integrations).
# Share the Ergon Labs page (and any sub-pages/databases to read/write) with the integration.
NOTION_TOKEN=

# Optional: pin a Notion API version (defaults to 2022-06-28).
NOTION_VERSION=2022-06-28

# NATS connection (bot_army_runtime reads these).
NATS_HOST=localhost
NATS_PORT=4222