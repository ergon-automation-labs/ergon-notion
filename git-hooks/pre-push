#!/bin/bash
# Git pre-push hook for Bot Army bots
# Requires proof-of-validation file from `make push` to proceed.

set -e

REPO_ROOT="$(git rev-parse --show-toplevel)"
PROOF_FILE="$REPO_ROOT/.push-validated"
PROOF_MAX_AGE_SECONDS=300  # 5 minutes

push_to_main=0
while read -r local_ref local_oid remote_ref remote_oid; do
  if [[ $remote_ref == "refs/heads/main" ]]; then
    push_to_main=1
  fi
done

if [[ $push_to_main -eq 1 ]]; then
  echo "🔍 Pre-push validation check (main branch)..."
  echo ""

  if [ ! -f "$PROOF_FILE" ]; then
    echo "❌ Proof-of-validation file not found: $PROOF_FILE"
    echo ""
    echo "Run: make push"
    echo "(This runs test → compile → credo, then creates proof file, then pushes)"
    exit 1
  fi

  PROOF_TIMESTAMP=$(cat "$PROOF_FILE")
  CURRENT_TIMESTAMP=$(date +%s)
  PROOF_AGE=$((CURRENT_TIMESTAMP - PROOF_TIMESTAMP))

  if [ "$PROOF_AGE" -gt "$PROOF_MAX_AGE_SECONDS" ]; then
    echo "❌ Proof-of-validation is stale ($(($PROOF_AGE / 60)) minutes old)"
    echo ""
    echo "Run: make push"
    echo "(To refresh validation and update proof file)"
    exit 1
  fi

  echo "✅ Proof-of-validation verified (fresh within last 5 min)"
  echo "📤 Proceeding with push..."
else
  echo "ℹ️  Pushing to feature branch - skipping validation"
fi

echo ""
exit 0
